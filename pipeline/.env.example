ANTHROPIC_API_KEY=sk-ant-...
GH_PAT=github_pat_...
GH_REPO=xsantcastx/xsantcastx
DEPLOY_TO_MAIN=false

# Social Media — Agent 5
# Set SOCIAL_DRAFT_MODE=false to actually post (default is true = draft only)
SOCIAL_DRAFT_MODE=true

# Twitter / X — get credentials at https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# LinkedIn — get access token at https://www.linkedin.com/developers/apps
# LINKEDIN_PERSON_URN format: urn:li:person:XXXXXXXX (find in LinkedIn API /me response)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=

# Reddit — create a script app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
