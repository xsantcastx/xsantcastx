rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Guestbook ────────────────────────────────────────────────────────────
    // Anyone can read; anyone can write (no auth required for guestbook)
    match /guestbook/{messageId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'message', 'timestamp'])
                   && request.resource.data.message is string
                   && request.resource.data.message.size() <= 1000
                   && request.resource.data.name is string
                   && request.resource.data.name.size() <= 100;
      allow update, delete: if false;
    }

    // ── User catalogs ─────────────────────────────────────────────────────────
    // Only the authenticated owner can read/write their own catalogs.
    match /users/{uid}/catalogs/{catalogId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Live Activity Feed ────────────────────────────────────────────────────
    // Written by the Claude Code PostToolUse hook; read by the /live page.
    match /claude-activity/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['type', 'text', 'timestamp'])
                   && request.resource.data.type in ['tool_call', 'thinking', 'success', 'error', 'system', 'output']
                   && request.resource.data.text is string
                   && request.resource.data.text.size() <= 300;
      allow delete: if false; // pruning handled by Cloud Function (Admin SDK)
      allow update: if false;
    }

    // ── Live Viewer Presence ──────────────────────────────────────────────────
    match /live-viewers/{sessionId} {
      allow read:   if true;
      allow create, update: if request.resource.data.keys().hasAll(['sessionId', 'timestamp']);
      allow delete: if true;
    }

    // ── Live Chat ─────────────────────────────────────────────────────────────
    match /live-chat/{msgId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'message', 'timestamp'])
                   && request.resource.data.message is string
                   && request.resource.data.message.size() <= 200
                   && request.resource.data.name is string
                   && request.resource.data.name.size() <= 20;
      allow update, delete: if false;
    }

    // ── Bot Agent Chat ────────────────────────────────────────────────────────
    match /bot-chat/{msgId} {
      allow read:   if true;
      allow create: if request.resource.data.keys().hasAll(['botName', 'message', 'timestamp'])
                   && request.resource.data.message is string
                   && request.resource.data.message.size() <= 500
                   && request.resource.data.botName is string
                   && request.resource.data.botName.size() <= 50;
      allow update, delete: if false;
    }

    // ── Changelog ────────────────────────────────────────────────────────────
    match /changelog/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Homepage newsletter subscribers ──────────────────────────────────────
    // Anyone can subscribe (create-only). No one can read or modify entries
    // from the client — the email list is only readable via the Admin SDK
    // (Cloud Function consumers / backend exporters).
    match /homepage_subscribers/{subId} {
      allow read: if false;
      allow create: if request.resource.data.keys().hasOnly(['email', 'subscribedAt', 'source'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() >= 5
                    && request.resource.data.email.size() <= 254
                    && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
                    && request.resource.data.subscribedAt is string
                    && request.resource.data.subscribedAt.size() <= 40
                    && request.resource.data.source is string
                    && request.resource.data.source.size() <= 100;
      allow update, delete: if false;
    }

    // ── Site stats (visit counter) ───────────────────────────────────────────
    // Anyone can read and bump the visitor count. Schema is strictly enforced:
    //   { count: number, lastVisit: string }
    // and we cap the count increment to +1 per request so a single client
    // can't griefthe counter into the stratosphere.
    match /site-stats/{statId} {
      allow read: if true;
      // Create the doc on first visit if it doesn't exist yet.
      allow create: if request.resource.data.keys().hasOnly(['count', 'lastVisit'])
                    && request.resource.data.count == 1
                    && request.resource.data.lastVisit is string
                    && request.resource.data.lastVisit.size() <= 50;
      // Increment by 1 only. lastVisit must be a string ISO timestamp.
      allow update: if request.resource.data.keys().hasOnly(['count', 'lastVisit'])
                    && request.resource.data.count is number
                    && request.resource.data.count == resource.data.count + 1
                    && request.resource.data.lastVisit is string
                    && request.resource.data.lastVisit.size() <= 50;
      allow delete: if false;
    }

    // ── Tool usage counter ───────────────────────────────────────────────────
    // Per-tool popularity counter written by ToolUsageService as
    //   setDoc(ref, { count: increment(1) }, { merge: true })
    // so each write contains ONLY { count }. Anyone may read and bump by +1.
    match /tool-usage/{toolId} {
      allow read: if true;
      // First use creates the doc with count == 1.
      allow create: if request.resource.data.keys().hasOnly(['count'])
                    && request.resource.data.count == 1;
      // Subsequent uses increment by exactly 1.
      allow update: if request.resource.data.keys().hasOnly(['count'])
                    && request.resource.data.count is number
                    && request.resource.data.count == resource.data.count + 1;
      allow delete: if false;
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
